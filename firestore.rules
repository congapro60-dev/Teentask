rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, displayName, photoURL, dob, parentEmail, trustScore, bio, skills, createdAt
    //
    // Collection: jobs
    // Fields: id, businessId, businessName, title, description, salary, slotsTotal, slotsFilled, deadline, location, type, category, status, tags, createdAt
    //
    // Collection: shadowing_events
    // Fields: id, mentorId, mentorName, companyName, title, description, date, price, slotsTotal, slotsRemaining, location, category, createdAt
    //
    // Collection: applications
    // Fields: id, jobId, businessId, studentId, studentName, parentEmail, portfolioUrl, parentStatus, finalStatus, createdAt
    //
    // Collection: reviews
    // Fields: id, businessId, studentId, studentName, studentPhoto, rating, comment, jobId, jobTitle, createdAt
    //
    // Collection: advertisements
    // Fields: id, businessId, businessName, title, description, imageUrl, linkUrl, status, createdAt
    //
    // Collection: support_messages
    // Fields: id, userId, userName, userEmail, subject, message, reply, status, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isBoss() {
      return isAuthenticated() && request.auth.token.email == "congapro60@gmail.com";
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
         isBoss() ||
         (request.auth.token.email == "cuong.vuviet@thedeweyschools.edu.vn"));
    }

    function isBusiness() {
      return hasRole('business');
    }

    function isParent() {
      return hasRole('parent');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /_connection_test_/{id} {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isBoss() || 
                    (isAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
                    (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['trustScore', 'role', 'balance']));
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.fromId == request.auth.uid &&
                    request.resource.data.fromId != request.resource.data.toId &&
                    request.resource.data.score >= 1 && request.resource.data.score <= 5;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if resource.data.status == 'active' || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.businessId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /shadowing_events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.mentorId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || 
        resource.data.businessId == request.auth.uid ||
        request.auth.token.email == resource.data.parentEmail ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId ||
        resource.data.businessId == request.auth.uid ||
        request.auth.token.email == resource.data.parentEmail ||
        isAdmin()
      );
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAdmin() || isAuthenticated(); // Allow users to send notifications (e.g. replies)
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /advertisements/{adId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.businessId == request.auth.uid);
      allow create: if isAuthenticated() && isBusiness();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /support_messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /survey_responses/{responseId} {
      allow read: if isAdmin();
      allow create: if true; // Allow anyone (even guests) to submit surveys as requested
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow create: if isAuthenticated() && request.resource.data.fromId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
    }

    match /relationships/{relId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.relatedUserId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
